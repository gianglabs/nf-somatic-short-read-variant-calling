nextflow_process {

    name "Test Process BEDTOOLS_GENOMECOV"
    script "../main.nf"
    process "BEDTOOLS_GENOMECOV"

    tag "modules"
    tag "modules_gianglabs"
    tag "bedtools"
    tag "bedtools/genomecov"

    test("homo_sapiens - bam") {

        when {
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/bam/processed.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/bam/processed.bam.bai', checkIfExists: true)
                ])
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
