nextflow_process {

    name "Test Process BWAMEM2_INDEX"
    script "../main.nf"
    process "BWAMEM2_INDEX"

    tag "modules"
    tag "modules_gianglabs"
    tag "bwa"
    tag "bwa/index"

    test("homo_sapiens - fasta") {

        when {
            process {
                """
                input[0] = Channel.of([
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/reference/chr22.fasta', checkIfExists: true)
                ])
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
