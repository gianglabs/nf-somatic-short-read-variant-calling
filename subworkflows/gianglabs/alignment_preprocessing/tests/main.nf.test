nextflow_workflow {

    name "Test Subworkflow PREPROCESSING"
    script "../main.nf"
    workflow "PREPROCESSING"

    tag "subworkflows"
    tag "subworkflows_gianglabs"
    tag "alignment_preprocessing"
    tag "preprocessing"

    test("homo_sapiens - bam - sambamba") {

        when {
            workflow {
                """
                input[0] = "sambamba"
                input[1] = Channel.of([
                    [ id: 'test', sample: 'test' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/bam/processed.bam', checkIfExists: true)
                ])
                input[2] = file(params.modules_testdata_base_path + 'genomics/homo_sapiens/reference/chr22.fasta', checkIfExists: true)
                input[3] = file(params.modules_testdata_base_path + 'genomics/homo_sapiens/reference/chr22.fasta.fai', checkIfExists: true)
                input[4] = file(params.modules_testdata_base_path + 'genomics/homo_sapiens/reference/chr22.dict', checkIfExists: true)
                input[5] = file(params.modules_testdata_base_path + 'genomics/homo_sapiens/vcf/dbsnp_146.hg38.vcf.gz', checkIfExists: true)
                input[6] = file(params.modules_testdata_base_path + 'genomics/homo_sapiens/vcf/dbsnp_146.hg38.vcf.gz.tbi', checkIfExists: true)
                input[7] = file(params.modules_testdata_base_path + 'genomics/homo_sapiens/vcf/mills_and_1000G.indels.vcf.gz', checkIfExists: true)
                input[8] = file(params.modules_testdata_base_path + 'genomics/homo_sapiens/vcf/mills_and_1000G.indels.vcf.gz.tbi', checkIfExists: true)
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success }
            )
        }
    }
}
